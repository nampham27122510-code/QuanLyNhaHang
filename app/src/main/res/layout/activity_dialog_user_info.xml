<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="XÁC NHẬN ĐẶT MÓN"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:textColor="#F28931"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/edtTenKhach"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Họ và tên"
        android:inputType="textPersonName"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/edtSDT"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Số điện thoại"
        android:inputType="phone"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn số bàn:"
        android:textStyle="bold"/>

    <Spinner
        android:id="@+id/spnSoBan"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/edtGhiChu"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="Ghi chú (Ví dụ: Không hành...)"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:background="@android:drawable/edit_text"
        android:padding="10dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnGuiDon"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="GỬI ĐƠN HÀNG"
        android:backgroundTint="#F28931"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>
</LinearLayout>