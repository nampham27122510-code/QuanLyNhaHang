<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#E8F5E9">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BÁO CÁO DOANH THU"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:textColor="#2E7D32"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnDoanhThuNgay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem doanh thu ngày hôm nay"
        android:backgroundTint="#4CAF50"/>

    <Button
        android:id="@+id/btnDoanhThuThang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xem doanh thu tháng này"
        android:backgroundTint="#388E3C"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/txtKetQuaBaoCao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Chọn một mục để xem..."
        android:textSize="18sp"
        android:textColor="#000000"
        android:padding="10dp"
        android:background="#FFFFFF"/>

</LinearLayout>